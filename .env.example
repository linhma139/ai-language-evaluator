# ============================================
# AI Microservice - Environment Template
# ============================================
# Hướng dẫn: Copy file này thành .env và điều chỉnh các giá trị:
#   cp .env.example .env

# --- LLM Configuration ---
# Tham khảo Ollama API (mặc định: http://localhost:11434/api/generate)
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL_NAME=hf.co/linhma139/Phi-3-IELTS-Scorer:Q4_K_M
LLM_TIMEOUT=120

# --- RabbitMQ Connection ---
# Format: amqp://user:password@host:port/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
MQ_PREFETCH_COUNT=1

# --- RabbitMQ Topology ---
MQ_EXCHANGE_NAME=ai_service
MQ_EXCHANGE_TYPE=direct

# --- Writing Service Queues ---
WRITING_QUEUE_NAME=writing.evaluate
WRITING_ROUTING_KEY=writing.evaluate

# --- Dead Letter Queue & Retry Policy ---
WRITING_DLQ_NAME=writing.evaluate.dlq
WRITING_DLQ_ROUTING_KEY=writing.evaluate.dlq
MQ_MAX_RETRIES=3
MQ_MESSAGE_TTL=120000

# --- Health Check ---
# Port dùng cho container health probes (K8s/Docker)
HEALTH_CHECK_PORT=8081
